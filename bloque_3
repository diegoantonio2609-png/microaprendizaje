<body style="margin: 0; padding: 0; font-family: 'Montserrat', sans-serif; background-color: #ffffff; color: #333333;">

    <!-- Section 3.1 -->
    <section style="padding: 60px 20px; max-width: 900px; margin: 0 auto;">
        
