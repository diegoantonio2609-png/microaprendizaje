<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Diagnóstico: ¿Cuál herramienta es para ti?</title>
<style>
  :root {
    --bg: #ffffff;
    --ink: #1a1a1a;
    --muted: #4a4a4a;
    --way-color: #2D5A4E;
    --way-light: rgba(45,90,78,0.08);
    --way-accent: #4A9B84;
    --nb-color: #1E3A5F;
    --nb-light: rgba(30,58,95,0.08);
    --nb-accent: #4A7AB5;
    --primary-red: #AB1E12;
    --primary-red-light: rgba(171,30,18,0.08);
    --card-bg: #fafafa;
    --border: rgba(0,0,0,0.05);
    --border-hover: rgba(0,0,0,0.15);
    --radius: 32px;
    --radius-sm: 16px;
    --shadow: 0 20px 60px rgba(0,0,0,0.05);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Montserrat', Helvetica, Arial, sans-serif;
    background: var(--bg);
    color: var(--ink);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 40px 20px 80px;
  }

  .main-container {
    width: 100%;
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cover-screen {
    text-align: center;
    width: 100%;
    max-width: 640px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 64px 40px;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    animation: fadeUp 0.7s ease forwards;
  }
  .cover-screen.hidden {
    display: none;
  }
  .cover-tag {
    display: inline-block;
    padding: 6px 16px;
    background-color: var(--primary-red-light);
    color: var(--primary-red);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.1em;
    border-radius: 50px;
    text-transform: uppercase;
    margin-bottom: 24px;
  }
  .cover-title {
    font-size: 40px;
    font-weight: 800;
    color: var(--ink);
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }
  .cover-desc {
    color: var(--muted);
    font-size: 18px;
    font-weight: 400;
    line-height: 1.8;
    max-width: 500px;
    margin: 0 auto 40px;
  }
  .btn-start {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: var(--primary-red);
    color: #ffffff;
    border: none;
    border-radius: 50px;
    padding: 16px 36px;
    font-family: 'Montserrat', Helvetica, Arial, sans-serif;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
  }
  .btn-start:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(171,30,18,0.2);
    background: #c52315;
  }

  .quiz-content {
    width: 100%;
    display: none;
    flex-direction: column;
    align-items: center;
  }
  .quiz-content.visible {
    display: flex;
  }

  .header {
    text-align: center;
    margin-bottom: 48px;
    opacity: 0;
    animation: fadeUp 0.7s ease forwards;
    width: 100%;
  }
  .header-tag {
    display: inline-block;
    padding: 6px 16px;
    background-color: var(--primary-red-light);
    color: var(--primary-red);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.1em;
    border-radius: 50px;
    text-transform: uppercase;
    margin-bottom: 24px;
  }
  .header h1 {
    font-size: clamp(32px, 5vw, 40px);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
    max-width: 600px;
    margin: 0 auto 16px;
  }
  .header h1 em { font-style: normal; color: var(--primary-red); }
  .header p {
    color: var(--muted);
    font-size: 18px;
    font-weight: 400;
    line-height: 1.8;
    max-width: 600px;
    margin: 0 auto;
  }

  .progress-wrap {
    width: 100%;
    max-width: 640px;
    margin-bottom: 32px;
    opacity: 0;
    animation: fadeUp 0.7s ease 0.15s forwards;
  }
  .progress-info {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 12px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .progress-bar-bg {
    width: 100%;
    height: 6px;
    background: var(--border);
    border-radius: 100px;
    overflow: hidden;
  }
  .progress-bar-fill {
    height: 100%;
    background: var(--primary-red);
    border-radius: 100px;
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card {
    width: 100%;
    max-width: 640px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 48px;
    box-shadow: var(--shadow);
    opacity: 0;
    animation: fadeUp 0.6s ease 0.25s forwards;
  }
  .question-number {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--primary-red);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .question-number::before {
    content: '';
    display: block;
    width: 8px;
    height: 8px;
    background-color: var(--primary-red);
    border-radius: 50%;
  }
  .question-text {
    font-size: clamp(20px, 3vw, 26px);
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 32px;
    color: var(--ink);
  }
  .options {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 40px;
  }
  .option {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    border: 2px solid var(--border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    background: #ffffff;
    text-align: left;
    width: 100%;
    font-family: 'Montserrat', Helvetica, Arial, sans-serif;
    color: var(--ink);
    transition: all 0.2s ease;
  }
  .option:hover { border-color: var(--border-hover); background: var(--card-bg); transform: translateY(-1px); }
  .option.selected { border-color: var(--primary-red); background: #ffffff; box-shadow: 0 8px 24px rgba(171,30,18,0.08); }
  .option-letter {
    flex-shrink: 0;
    width: 32px; height: 32px;
    border-radius: 50%;
    background-color: var(--card-bg);
    color: var(--muted);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
    transition: all 0.2s;
  }
  .option.selected .option-letter { background-color: var(--primary-red); color: #ffffff; }
  .option-text { font-size: 16px; line-height: 1.5; font-weight: 500; }
  .option.selected .option-text { color: var(--primary-red); }

  .nav-row { display: flex; justify-content: flex-end; }
  .btn-next {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--ink);
    color: #ffffff;
    border: none;
    border-radius: 50px;
    padding: 16px 32px;
    font-family: 'Montserrat', Helvetica, Arial, sans-serif;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s ease;
    opacity: 0;
    pointer-events: none;
  }
  .btn-next.visible { opacity: 1; pointer-events: all; }
  .btn-next:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(0,0,0,0.15); background: #333; }
  .btn-next:hover svg { transform: translateX(4px); }
  .btn-next svg { transition: transform 0.2s ease; }

  .result-wrap {
    width: 100%;
    max-width: 640px;
    display: none;
  }
  .result-wrap.visible {
    display: block;
    animation: fadeUp 0.7s ease forwards;
  }

  .result-card {
    border-radius: var(--radius);
    padding: 64px 48px;
    border: 1px solid var(--border);
    background: var(--card-bg);
    box-shadow: var(--shadow);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .result-card.wayground { border-top: 6px solid var(--way-color); }
  .result-card.notebooklm { border-top: 6px solid var(--nb-color); }

  .result-label {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 24px;
    display: inline-block;
    padding: 6px 16px;
    border-radius: 50px;
  }
  .result-card.wayground .result-label { color: var(--way-color); background: var(--way-light); }
  .result-card.notebooklm .result-label { color: var(--nb-color); background: var(--nb-light); }
  .result-tool {
    font-size: clamp(40px, 8vw, 56px);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }
  .result-card.wayground .result-tool { color: var(--way-color); }
  .result-card.notebooklm .result-tool { color: var(--nb-color); }
  .result-divider {
    width: 60px; height: 4px;
    margin: 32px auto;
    border-radius: 100px;
  }
  .result-card.wayground .result-divider { background: var(--way-accent); }
  .result-card.notebooklm .result-divider { background: var(--nb-accent); }
  .result-msg {
    font-size: 18px;
    line-height: 1.7;
    color: var(--muted);
    max-width: 480px;
    margin: 0 auto;
    font-weight: 400;
  }
  .result-footnote {
    margin-top: 32px;
    font-size: 14px;
    color: var(--muted);
    font-style: italic;
  }

  /* ── TIE SCREEN ── */
  .tie-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 48px;
    box-shadow: var(--shadow);
    text-align: center;
  }
  .tie-label {
    display: inline-block;
    padding: 6px 16px;
    background-color: rgba(0,0,0,0.05);
    color: var(--ink);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.1em;
    border-radius: 50px;
    text-transform: uppercase;
    margin-bottom: 24px;
  }
  .tie-title {
    font-size: clamp(24px, 4vw, 32px);
    font-weight: 800;
    line-height: 1.3;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }
  .tie-sub {
    font-size: 16px;
    color: var(--muted);
    font-weight: 400;
    line-height: 1.7;
    max-width: 480px;
    margin: 0 auto 32px;
  }
  .tie-summary {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 32px;
    text-align: left;
  }
  .tie-col {
    border-radius: var(--radius-sm);
    padding: 24px;
    border: 1px solid var(--border);
    background: #ffffff;
  }
  .tie-col-title {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .tie-col.way .tie-col-title { color: var(--way-color); }
  .tie-col.nb  .tie-col-title { color: var(--nb-color); }
  .tie-col ul { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .tie-col ul li {
    font-size: 14px;
    line-height: 1.6;
    color: var(--muted);
    font-weight: 500;
    padding-left: 20px;
    position: relative;
  }
  .tie-col ul li::before {
    content: '→';
    position: absolute;
    left: 0;
    font-weight: 700;
  }
  .tie-col.way ul li::before { color: var(--way-accent); }
  .tie-col.nb ul li::before { color: var(--nb-accent); }

  .tie-buttons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .tie-btn {
    padding: 20px;
    border-radius: var(--radius-sm);
    border: 2px solid transparent;
    font-family: 'Montserrat', Helvetica, Arial, sans-serif;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    line-height: 1.5;
    background: #ffffff;
  }
  .tie-btn strong { display: block; font-size: 18px; font-weight: 800; margin-top: 8px; }
  .tie-btn.way { border-color: var(--way-light); color: var(--muted); }
  .tie-btn.way strong { color: var(--way-color); }
  .tie-btn.nb  { border-color: var(--nb-light);  color: var(--muted); }
  .tie-btn.nb strong { color: var(--nb-color); }
  .tie-btn.way:hover { border-color: var(--way-color); background: var(--way-light); transform: translateY(-2px); box-shadow: 0 10px 20px rgba(45,90,78,0.1); }
  .tie-btn.nb:hover { border-color: var(--nb-color); background: var(--nb-light); transform: translateY(-2px); box-shadow: 0 10px 20px rgba(30,58,95,0.1); }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .card.exiting { animation: slideOut 0.3s ease forwards; }
  .card.entering { animation: slideIn 0.4s ease forwards; }
  @keyframes slideOut {
    from { opacity: 1; transform: translateY(0); }
    to   { opacity: 0; transform: translateY(-16px); }
  }
  @keyframes slideIn {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 600px) {
    .card, .tie-card, .cover-screen { padding: 32px 24px; }
    .result-card { padding: 48px 24px; }
    .tie-summary, .tie-buttons { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<div class="main-container">

<div class="cover-screen" id="coverScreen">
  <div class="cover-tag">Bloque 1 · Actividad</div>
  <h1 class="cover-title">Diagnóstico de elección de herramienta</h1>
  <p class="cover-desc">Este breve diagnóstico te ayudará a descubrir la herramienta más adecuada para ti en los próximos bloques. No hay respuestas correctas, solo queremos conocer tu contexto.</p>
  <button class="btn-start" onclick="startQuiz()">
    Comenzar
  </button>
</div>

<div class="quiz-content" id="quizContent">
<div class="header">
  <div class="header-tag">Bloque 1 · Diagnóstico inicial</div>
  <h1>¿Qué herramienta es <em>la tuya</em>?</h1>
  <p>Responde con honestidad — no hay respuestas correctas. Estas seis preguntas están pensadas para conocer tu contexto y lo que quieres lograr, no para evaluarte. Al final te sugeriremos una herramienta con la que podrás construir tu recurso de microaprendizaje.</p>
</div>

<div class="progress-wrap">
  <div class="progress-info">
    <span id="progressLabel">Pregunta 1 de 6</span>
    <span id="progressPct">0%</span>
  </div>
  <div class="progress-bar-bg">
    <div class="progress-bar-fill" id="progressFill" style="width:0%"></div>
  </div>
</div>

<div class="card" id="card">
  <div class="question-number" id="qNum"></div>
  <div class="question-text" id="qText"></div>
  <div class="options" id="optionsContainer"></div>
  <div class="nav-row">
    <button class="btn-next" id="btnNext" onclick="next()">
      Continuar
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</div>

<!-- EMPATE -->
<div class="result-wrap" id="tieWrap">
  <div class="tie-card">
    <div class="tie-label">Diagnóstico · Empate</div>
    <div class="tie-title">Tu perfil encaja con las dos herramientas.</div>
    <div class="tie-sub">Revisamos tus respuestas y hay elementos que apuntan en las dos direcciones. Tú decides con cuál continuar.</div>
    <div class="tie-summary" id="tieSummary"></div>
    <div class="tie-buttons">
      <button class="tie-btn way" onclick="chooseTie('wayground')">
        Quiero empezar con
        <strong>Wayground</strong>
      </button>
      <button class="tie-btn nb" onclick="chooseTie('notebooklm')">
        Quiero empezar con
        <strong>NotebookLM</strong>
      </button>
    </div>
  </div>
</div>
</div>

<!-- RESULTADO CLARO -->
<div class="result-wrap" id="resultWrap">
  <div class="result-card" id="resultCard">
    <div class="result-label" id="resultLabel"></div>
    <div class="result-tool" id="resultTool"></div>
    <div class="result-divider"></div>
    <div class="result-msg" id="resultMsg"></div>
    <div class="result-footnote">En el Bloque 3 la conocerás a fondo.</div>
  </div>
</div>

<script>
function startQuiz() {
  document.getElementById('coverScreen').classList.add('hidden');
  document.getElementById('quizContent').classList.add('visible');
}

const questions = [
  {
    text: "¿Desde dónde partes para crear este recurso?",
    options: [
      { letter: "A", text: "Tengo material que ya uso con mis estudiantes: lecturas, presentaciones, apuntes, PDFs.", way: 0, nb: 2,
        tieWay: null, tieNB: "Ya tienes material y quieres transformarlo" },
      { letter: "B", text: "No tengo material estructurado, pero tengo claro qué quiero que aprendan.", way: 2, nb: 0,
        tieWay: "Partes de una idea nueva, sin material previo", tieNB: null }
    ]
  },
  {
    text: "¿Qué quieres que logre tu estudiante con este recurso?",
    options: [
      { letter: "A", text: "Que practique o demuestre algo: responder, aplicar, resolver, decidir.", way: 2, nb: 0,
        tieWay: "Quieres que cada paso sea interactivo", tieNB: null },
      { letter: "B", text: "Que comprenda algo que le resulta difícil: un concepto, un proceso, una lectura compleja.", way: 0, nb: 2,
        tieWay: null, tieNB: "El reto es que tus estudiantes entiendan algo denso o complejo" },
      { letter: "C", text: "Que repase o consolide algo que ya trabajaron en clase.", way: 1, nb: 1,
        tieWay: "Buscas una actividad con retroalimentación integrada", tieNB: "La interactividad puede venir al final" }
    ]
  },
  {
    text: "Si pudieras ver tu recurso terminado, ¿a qué se parece más?",
    options: [
      { letter: "A", text: "Una actividad donde el estudiante avanza respondiendo o eligiendo, y recibe retroalimentación en el camino.", way: 1, nb: 0,
        tieWay: "Buscas una actividad con retroalimentación integrada", tieNB: null },
      { letter: "B", text: "Un material que el estudiante escucha, lee o ve para entender algo con más claridad.", way: 0, nb: 1,
        tieWay: null, tieNB: "El reto es que tus estudiantes entiendan algo denso o complejo" },
      { letter: "C", text: "Primero entiende, después practica.", way: 1, nb: 1,
        tieWay: "Buscas una actividad con retroalimentación integrada", tieNB: "La interactividad puede venir al final" }
    ]
  },
  {
    text: "¿Cuándo es más importante que tu estudiante interactúe?",
    options: [
      { letter: "A", text: "Durante todo el recorrido: cada paso es activo.", way: 2, nb: 0,
        tieWay: "Quieres que cada paso sea interactivo", tieNB: null },
      { letter: "B", text: "Al final: primero recibe el contenido, después demuestra lo que entendió.", way: 0, nb: 2,
        tieWay: null, tieNB: "La interactividad puede venir al final" },
      { letter: "C", text: "No lo tengo claro todavía.", way: 0, nb: 0,
        tieWay: null, tieNB: null }
    ]
  },
  {
    text: "¿Cómo acceden tus estudiantes al material fuera del aula?",
    options: [
      { letter: "A", text: "Principalmente desde el celular.", way: 1, nb: 0,
        tieWay: "Tus estudiantes acceden principalmente desde celular", tieNB: null },
      { letter: "B", text: "Desde computadora o laptop.", way: 0, nb: 1,
        tieWay: null, tieNB: "Tus estudiantes trabajan desde computadora" },
      { letter: "C", text: "Es variable o no lo sé con certeza.", way: 0, nb: 0,
        tieWay: null, tieNB: null }
    ]
  },
  {
    text: "¿Cómo van a usar este recurso?",
    options: [
      { letter: "A", text: "De forma autónoma, sin mi acompañamiento directo.", way: 1, nb: 0,
        tieWay: "El recurso lo usarán de forma autónoma", tieNB: null },
      { letter: "B", text: "Como parte de una actividad de clase, con mi guía o contexto previo.", way: 0, nb: 1,
        tieWay: null, tieNB: "Vas a acompañar el uso del recurso en clase" },
      { letter: "C", text: "Ambas son posibles.", way: 0, nb: 0,
        tieWay: null, tieNB: null }
    ]
  }
];

let current = 0;
let selected = null;
let scoreWay = 0;
let scoreNB  = 0;
let answers  = [];

function render() {
  const q = questions[current];
  const label = `Pregunta ${current + 1} de ${questions.length}`;
  document.getElementById('qNum').textContent = label;
  document.getElementById('progressLabel').textContent = label;
  const pct = Math.round((current / questions.length) * 100);
  document.getElementById('progressPct').textContent = pct + '%';
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('qText').textContent = q.text;

  const container = document.getElementById('optionsContainer');
  container.innerHTML = '';
  q.options.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'option';
    btn.innerHTML = `<span class="option-letter">${opt.letter}</span><span class="option-text">${opt.text}</span>`;
    btn.onclick = () => selectOption(i);
    container.appendChild(btn);
  });

  selected = null;
  document.getElementById('btnNext').classList.remove('visible');
}

function selectOption(i) {
  selected = i;
  document.querySelectorAll('.option').forEach((b, idx) => b.classList.toggle('selected', idx === i));
  document.getElementById('btnNext').classList.add('visible');
}

function next() {
  if (selected === null) return;
  const opt = questions[current].options[selected];
  scoreWay += opt.way;
  scoreNB  += opt.nb;
  answers.push(opt);

  if (current < questions.length - 1) {
    const card = document.getElementById('card');
    card.classList.add('exiting');
    setTimeout(() => {
      current++;
      render();
      card.classList.remove('exiting');
      card.classList.add('entering');
      setTimeout(() => card.classList.remove('entering'), 380);
    }, 260);
  } else {
    finalize();
  }
}

function finalize() {
  document.getElementById('progressPct').textContent = '100%';
  document.getElementById('progressFill').style.width = '100%';
  document.getElementById('progressLabel').textContent = 'Completado';

  const card = document.getElementById('card');
  card.classList.add('exiting');
  setTimeout(() => {
    card.style.display = 'none';
    if (scoreWay === scoreNB) {
      buildTie();
      document.getElementById('tieWrap').classList.add('visible');
    } else {
      showWinner(scoreWay > scoreNB ? 'wayground' : 'notebooklm');
    }
  }, 260);
}

function buildTie() {
  const wayItems = answers.filter(o => o.tieWay).map(o => o.tieWay);
  const nbItems  = answers.filter(o => o.tieNB).map(o => o.tieNB);

  const wayHTML = wayItems.length
    ? wayItems.map(t => `<li>${t}</li>`).join('')
    : '<li>Tus respuestas no muestran señales claras hacia Wayground</li>';
  const nbHTML = nbItems.length
    ? nbItems.map(t => `<li>${t}</li>`).join('')
    : '<li>Tus respuestas no muestran señales claras hacia NotebookLM</li>';

  document.getElementById('tieSummary').innerHTML = `
    <div class="tie-col way">
      <div class="tie-col-title">Wayground si…</div>
      <ul>${wayHTML}</ul>
    </div>
    <div class="tie-col nb">
      <div class="tie-col-title">NotebookLM si…</div>
      <ul>${nbHTML}</ul>
    </div>
  `;
}

function chooseTie(tool) {
  document.getElementById('tieWrap').classList.remove('visible');
  document.getElementById('tieWrap').style.display = 'none';
  showWinner(tool);
}

function showWinner(tool) {
  const card  = document.getElementById('resultCard');
  const tool_ = document.getElementById('resultTool');
  const msg   = document.getElementById('resultMsg');
  const lbl   = document.getElementById('resultLabel');

  lbl.textContent = 'Tu herramienta recomendada es';

  if (tool === 'wayground') {
    card.className = 'result-card wayground';
    tool_.textContent = 'Wayground';
    msg.textContent = 'Wayground está pensada para crear experiencias donde el estudiante aprende haciendo. En el Bloque 3 la conocerás a fondo.';
  } else {
    card.className = 'result-card notebooklm';
    tool_.textContent = 'NotebookLM';
    msg.textContent = 'NotebookLM está pensada para transformar material que ya tienes en contenido claro y accesible para tus estudiantes. En el Bloque 3 la conocerás a fondo.';
  }

  document.getElementById('resultWrap').classList.add('visible');
}

render();
</script>
