<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1200" />
    <title>Sistema Visual MiniTIC — Preview</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        font-family:
          "Inter",
          -apple-system,
          sans-serif;
        background: #f4f4f4;
        padding: 40px;
        display: flex;
        flex-direction: column;
        gap: 40px;
        max-width: 1280px;
        margin: 0 auto;
      }

      /* ─── SECTION LABEL ─── */
      .section-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #999;
        margin-bottom: 12px;
      }

      /* ══════════════════════════════════════════
     1. BANNER HERO
  ══════════════════════════════════════════ */
      .hero {
        position: relative;
        width: 1200px;
        height: 300px;
        background: #0d0d0d;
        display: flex;
        align-items: center;
        overflow: hidden;
      }
      .hero-bar {
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 6px;
        background: #ab1e12;
      }
      .hero-tag {
        position: absolute;
        top: 0;
        right: 0;
        background: #ab1e12;
        color: #ffffff;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        padding: 9px 18px;
        font-family: "Inter", sans-serif;
      }
      .hero-content {
        padding-left: 72px;
        display: flex;
        flex-direction: column;
        gap: 14px;
      }
      .hero-eyebrow {
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #ab1e12;
        font-family: "Inter", sans-serif;
      }
      .hero-title {
        font-size: 48px;
        font-weight: 800;
        line-height: 1.05;
        letter-spacing: -0.025em;
        color: #ffffff;
        font-family: "Inter", sans-serif;
        max-width: 680px;
      }

      /* ══════════════════════════════════════════
     2. BLOQUE DE BIENVENIDA
  ══════════════════════════════════════════ */
      .welcome {
        background: #ffffff;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
      }
      .welcome-text {
        padding: 52px 56px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 20px;
        border-right: 1px solid #e8e8e8;
      }
      .welcome-eyebrow {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #ab1e12;
        font-family: "Inter", sans-serif;
      }
      .welcome-title {
        font-size: 28px;
        font-weight: 800;
        line-height: 1.15;
        letter-spacing: -0.02em;
        color: #0d0d0d;
        font-family: "Inter", sans-serif;
      }
      .welcome-body {
        font-size: 15px;
        font-weight: 400;
        line-height: 1.7;
        color: #444;
        font-family: "Inter", sans-serif;
      }
      .welcome-video {
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f4f4f4;
      }
      .video-placeholder {
        width: calc(100% - 56px);
        aspect-ratio: 16/9;
        border: 1px solid #0d0d0d;
        background: #ffffff;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin: 28px;
      }
      .video-icon {
        width: 40px;
        height: 40px;
        border: 2px solid #0d0d0d;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .video-icon svg {
        display: block;
      }
      .video-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #999;
        font-family: "Inter", sans-serif;
      }

      /* ══════════════════════════════════════════
     3. TARJETAS DE BLOQUE
  ══════════════════════════════════════════ */
      .cards-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
        border: 1px solid #e0e0e0;
      }
      .card {
        background: #ffffff;
        border-top: 3px solid #ab1e12;
        border-right: 1px solid #e0e0e0;
        padding: 36px 32px 32px;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .card:last-child {
        border-right: none;
      }
      .card-number {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #ab1e12;
        font-family: "Inter", sans-serif;
      }
      .card-title {
        font-size: 18px;
        font-weight: 800;
        line-height: 1.2;
        letter-spacing: -0.015em;
        color: #0d0d0d;
        font-family: "Inter", sans-serif;
        flex: 1;
      }
      .card-desc {
        font-size: 14px;
        font-weight: 400;
        line-height: 1.6;
        color: #666;
        font-family: "Inter", sans-serif;
        min-height: 44px;
      }
      .card-btn {
        display: inline-block;
        margin-top: 8px;
        padding: 10px 20px;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #ab1e12;
        border: 1.5px solid #ab1e12;
        background: transparent;
        cursor: pointer;
        font-family: "Inter", sans-serif;
        text-decoration: none;
        text-align: center;
        transition:
          background 0.15s,
          color 0.15s;
      }
      .card-btn:hover {
        background: #ab1e12;
        color: #ffffff;
      }
    </style>
  </head>
